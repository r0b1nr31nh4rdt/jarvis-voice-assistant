# Jarvis — Umgebungsvariablen
# Kopiere diese Datei: cp .env.example .env
# Trage deine echten Werte ein. Die .env wird NICHT in Git eingecheckt.

# API Keys
ANTHROPIC_API_KEY=sk-ant-...
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id

# Persönliche Einstellungen
USER_NAME=Dein Name
USER_SALUTATION=Sir
USER_ROLE=Deine Taetigkeit
CITY=Hamburg
JARVIS_LANGUAGE=german
IDLE_TIMEOUT_MINUTES=60
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Obsidian (optional)
OBSIDIAN_VAULT_PATH=/Users/dein_user/obsidian/vault
OBSIDIAN_INBOX_PATH=/Users/dein_user/obsidian/vault/inbox

# Launch-Session (scripts/launch-session.sh)
APPLE_MUSIC_PLAYLIST=Deine Playlist
BROWSER_URL=https://your-website.com
