# Jarvis — Umgebungsvariablen
# Kopiere diese Datei: cp .env.example .env
# Trage deine echten Werte ein. Die .env wird NICHT in Git eingecheckt.

# API Keys
ANTHROPIC_API_KEY=sk-ant-...
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id

# Persönliche Einstellungen
USER_NAME=Dein Name
USER_ADDRESS=Sir
CITY=Hamburg

# Pfade (optional)
OBSIDIAN_INBOX_PATH=/Users/dein_user/path/to/obsidian/inbox

# Launch-Session (scripts/launch-session.sh)
APPLE_MUSIC_PLAYLIST=Deine Playlist
BROWSER_URL=https://your-website.com
